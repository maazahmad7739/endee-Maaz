
# Ignore build directory
build/
# Ignore build like directory
build*/
# Ignore all files in the build directory
build/*

# Ignore tests build directory
tests/build/
tests/build*/

# Test binaries
tests/**/ndd_filter_test

# macOS debug symbols
*.dSYM/

# Sometimes data files are created for tetsing
data/
data/*

# VS Code directory
.vscode/
.vscode/*

# Frontend
frontend/
frontend/*

# DS Store
.DS_Store

# Build logs
*.log

# Python cache
__pycache__/
*.pyc

# Project data
app/data/sample_images/*
!app/data/sample_images/.gitkeep
